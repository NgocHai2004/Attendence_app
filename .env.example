# =============================================================
# Face Recognition Attendance System - Environment Variables
# =============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================

# --- Required: Application Security ---
# Secret key for session encryption. MUST be set in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# --- Required: MongoDB ---
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=attendance_app

# --- Optional: CORS ---
# Comma-separated list of allowed origins. Leave empty for wildcard (not recommended for production).
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=

# --- Optional: Default Admin Account ---
# Only used when no admin exists yet (first startup).
# If DEFAULT_ADMIN_PASSWORD is not set, a random one will be generated and printed to console.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@localhost
DEFAULT_ADMIN_PASSWORD=

# --- Optional: Telegram Bot ---
# Get these from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
